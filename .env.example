# ============================================================================
# SyncDoc Environment Variables
# ============================================================================
# For Doppler users: export these via `doppler run -- docker compose up`
# For non-Doppler users: copy this file to `.env` and fill in your values.
# ============================================================================

# ============================================================================
# Database / Cache (For Local Development)
# ============================================================================
# Docker Compose will auto-create these. No changes needed for local `docker-compose up`
DATABASE_URL=postgresql+asyncpg://syncdoc:syncdoc_dev@postgres:5432/syncdoc
REDIS_URL=redis://redis:6379/0

# ============================================================================
# Runtime / URLs
# ============================================================================
ENVIRONMENT=development
PYTHONUNBUFFERED=1
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
ALLOW_SELF_REGISTER=true

# ============================================================================
# Authentication & Security
# ============================================================================
# For local development, this default is fine. Change for production deployments.
JWT_SECRET_KEY=your-secret-key-here-change-for-production
GH_CLIENT_ID=
GH_CLIENT_SECRET=
GITHUB_PAT=

# ============================================================================
# LLM (Optional - AI Features)
# ============================================================================
# Leave empty to disable AI features. To enable, add your own API keys.
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_API_KEY=<add-your-openai-key-here-for-optional-ai-features>
LLM_ENDPOINT_URL=https://api.openai.com/v1

# ============================================================================
# Notifications
# ============================================================================
SLACK_WEBHOOK_URL=

# ============================================================================
# Email / SMTP
# ============================================================================
EMAIL_ENABLED=false
EMAIL_PROVIDER=smtp
EMAIL_FROM_ADDRESS=no-reply@syncdoc.dev
EMAIL_FROM_NAME=SyncDoc
EMAIL_REPLY_TO=support@syncdoc.dev
REGISTRATION_NOTIFY_TO=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
PASSWORD_RESET_EXPIRE_MINUTES=60

# If you send through Gmail but want the visible sender to be `@syncdoc.dev`,
# add that address as an authorized "Send mail as" alias in the sending mailbox.
